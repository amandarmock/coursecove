# E2E Test Environment Variables
# Copy to .env.e2e and fill in values

# Base URL for tests
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Test User Credentials (create dedicated test users in Clerk)
E2E_ADMIN_EMAIL=e2e-admin@yourorg.test
E2E_ADMIN_PASSWORD=SecureTestPassword123!
E2E_INSTRUCTOR_EMAIL=e2e-instructor@yourorg.test
E2E_INSTRUCTOR_PASSWORD=SecureTestPassword123!
E2E_STUDENT_EMAIL=e2e-student@yourorg.test
E2E_STUDENT_PASSWORD=SecureTestPassword123!

# Test Organization ID (internal org ID from your database)
E2E_ORG_ID=org_test_xxx

# Clerk Keys (same as development or dedicated test instance)
# CLERK_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
